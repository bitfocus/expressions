{
	"name": "@companion-app/expressions",
	"version": "0.2.3",
	"description": "Parser and evaluator for Bitfocus Companion's expression dialect",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bitfocus/expressions.git"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": "./dist/index.js",
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"CHANGELOG.md"
	],
	"engines": {
		"node": ">=22.20"
	},
	"scripts": {
		"build": "rimraf --glob dist \"*.tsbuildinfo\" && tsc --build tsconfig.json",
		"lint": "eslint .",
		"unit": "vitest run",
		"unit:watch": "vitest",
		"test": "yarn lint && yarn unit"
	},
	"dependencies": {
		"acorn": "^8.17.0",
		"jsonpath-plus": "^10.4.0",
		"type-fest": "^5.7.0",
		"unicode-segmenter": "^0.16.0"
	},
	"devDependencies": {
		"@companion-module/tools": "^3.0.2",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@tsconfig/node22": "^22.0.5",
		"@types/node": "^22.20.0",
		"eslint": "^10.5.0",
		"prettier": "^3.8.4",
		"rimraf": "^6.1.3",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.62.0",
		"vitest": "^4.1.9"
	},
	"packageManager": "yarn@4.17.0"
}
